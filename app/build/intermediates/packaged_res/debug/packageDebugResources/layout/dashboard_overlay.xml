<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#E6222222"
    android:padding="8dp"
    android:layout_margin="8dp">

    <!-- Drag handle + close/minimize buttons -->
    <LinearLayout
        android:id="@+id/dragHandle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📊 数据面板"
            android:textColor="#FFFFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnMinimize"
            android:layout_width="32dp"
            android:layout_height="28dp"
            android:text="—"
            android:textColor="#FFFFFFFF"
            android:textSize="14sp"
            android:backgroundTint="#FF555555"
            android:padding="0dp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnClose"
            android:layout_width="32dp"
            android:layout_height="28dp"
            android:text="✕"
            android:textColor="#FFFFFFFF"
            android:textSize="14sp"
            android:backgroundTint="#FFB71C1C"
            android:padding="0dp" />
    </LinearLayout>

    <!-- Content area (toggled by minimize) -->
    <LinearLayout
        android:id="@+id/contentArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvOrders"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="订单数:     0 = 0 + 0"
            android:textColor="#FFFFEB3B"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:paddingTop="4dp" />

        <TextView
            android:id="@+id/tvMorning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="早高峰总时长: 0.0h = 0.0h + 0.0h"
            android:textColor="#FFFFFFFF"
            android:textSize="13sp"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/tvEvening"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="晚高峰总时长: 0.0h = 0.0h + 0.0h"
            android:textColor="#FFFFFFFF"
            android:textSize="13sp"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/tvNight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="夜高峰总时长: 0.0h = 0.0h + 0.0h"
            android:textColor="#FFFFFFFF"
            android:textSize="13sp"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/tvWeekend"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="周末总时长:   0.0h = 0.0h + 0.0h"
            android:textColor="#FFFFFFFF"
            android:textSize="13sp"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/tvTotal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="总高峰时长:  0.0h"
            android:textColor="#FF00E676"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:paddingTop="4dp" />

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="6dp">

            <Button
                android:id="@+id/btnRefreshOrders"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="刷新订单"
                android:textColor="#FFFFFFFF"
                android:textSize="13sp"
                android:backgroundTint="#FF1976D2"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnPause"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="⏹ 停止计时"
                android:textColor="#FFFFFFFF"
                android:textSize="13sp"
                android:backgroundTint="#FFFF9800" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
